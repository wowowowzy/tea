<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >

<mapper namespace="com.example.tea.mapper.ChatMapper">

    <insert id="add">
        INSERT INTO `sys_history` ( `datetime`, `content`, `role`, `session_id`,`user_id`)
        VALUES (
                   #{datetime},
                   #{content},
                   #{role},
                   #{sessionId},
                   #{userId}
               );
    </insert>
</mapper>

